# Database
# 주의: user:password를 실제 PostgreSQL 사용자 이름으로 변경하세요
# macOS의 경우 보통: postgresql://$(whoami)@localhost:5432/cotion_dev
DATABASE_URL=postgresql://user:password@localhost:5432/cotion_dev

# JWT Secrets
# 프로덕션 환경에서는 반드시 강력한 랜덤 문자열로 변경하세요
JWT_ACCESS_SECRET=your-access-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# FCM 푸시 알림 (선택)
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"으로 받은
# JSON 전체를 한 줄로 넣으세요. 비워두면 푸시는 비활성화되고 인앱·카카오 알림만 동작합니다.
# 예: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
FIREBASE_SERVICE_ACCOUNT=
